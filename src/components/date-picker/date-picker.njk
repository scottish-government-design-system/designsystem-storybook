{%- macro datePicker(params) -%}
{%- if params.minDate and params.maxDate -%}
{%- set moduleDateRange = ["data-maxdate=\"", params.maxDate, "\" data-mindate=\"", params.minDate, "\""] | join %}
{%- endif -%}
<div data-module="ds-datepicker" class="ds_datepicker  {% if params.isMultipleFields %}ds_datepicker--multiple{% endif %}">
    {%- if params.isMultipleFields %}
    <div class="ds_datepicker__input-wrapper">
        <div>
            <label class="ds_label" for="day">Day</label>
            <input id="day" name="day" class="ds_input ds_input--fixed-2  js-datepicker-date">
        </div>
        <div>
            <label class="ds_label" for="month">Month</label>
            <input id="month" name="month" class="ds_input ds_input--fixed-2  js-datepicker-month">
        </div>
        <div>
            <label class="ds_label" for="year">Year</label>
            <input id="year" name="year" class="ds_input ds_input--fixed-4  js-datepicker-year">
        </div>
    </div>
    {%- else %}
    <label class="ds_label" for="start-date">{{ params.label }}</label>
    <div class="ds_input__wrapper">
        <input {%- if params.dateFormat %} data-dateformat="{{params.dateFormat}}"{%- endif %} id="start-date" name="start-date" {{ moduleDateRange | safe}} placeholder="{{ params.placeholder }}" type="text" class="ds_input ds_input--fixed-10">
    </div>
    {%- endif %}
</div>
{%- endmacro -%}

{{datePicker({
    dateFormat: dateFormat,
    isMultipleFields: isMultipleFields,
    label: label,
    minDate: minDate,
    maxDate: maxDate,
    placeholder: placeholder
})}}
