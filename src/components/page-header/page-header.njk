{%- macro pageHeader(params) -%}
{%- from 'src/components/page-metadata/page-metadata.njk' import pageMetadata -%}
<header class="ds_page-header">
    {%- if params.label %}
    <span class="ds_page-header__label ds_content-label">{%- if params.tag %}<span class="ds_tag">{{ params.tag }}</span> {% endif %}{{ params.label }}</span>
    {%- elseif params.tag -%}
    <span class="ds_tag">{{ params.tag }}</span>
    {%- endif %}
    <h1 class="ds_page-header__title">{{ params.heading }}</h1>
    {%- if params.hasMetadata %}
    {{pageMetadata({
        items: params.metadataItems
    })}}
    {%- endif %}
</header>
{%- endmacro -%}

{{pageHeader({
    hasMetadata: hasMetadata,
    heading: heading,
    label: label,
    metadataItems: metadataItems,
    tag: tag
})}}
