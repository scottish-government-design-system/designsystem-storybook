{%- macro errorSummary(params) -%}
<div class="ds_error-summary" id="error-summary" aria-labelledby="error-summary-title" role="alert">
    <h2 class="ds_error-summary__title" id="error-summary-title">{{params.title | default('There is a problem')}}</h2>
    {%- if params.errors %}
    <ul class="ds_error-summary__list">
        {%- for item in params.errors %}
        <li>
            <a href="{{ item.href }}">{{ item.content }}</a>
        </li>
        {%- endfor %}
    </ul>
    {% endif -%}
</div>
{%- endmacro -%}

{{errorSummary({
    errors: errors,
    title: title
})}}
