{%- macro taskList(params) -%}
{%- from 'src/components/task-list/task.njk' import task -%}
{%- if params.title %}
<{{ params.headingLevel }} class="ds_task-list-heading">{{ params.title }}</{{ params.headingLevel }}>
{%- endif %}
{%- if params.intro %}
<p class="ds_task-list-intro">{{ params.intro }}</p>
{%- endif %}
{%- if params.tasks %}
<ul class="ds_task-list">
    {%- for item in params.tasks %}
        {{task({
            content: item.content,
            headingLevel: taskHeadingLevel,
            href: item.href,
            id: item.id,
            status: item.status,
            title: item.title
        })}}
    {%- endfor %}
</ul>
{%- endif %}
{%- if params.groups %}
<ul class="ds_task-list-group">
    {%- for group in params.groups %}
    <li class="ds_task-list-group__section">
        {%- if group.title %}
        <{{ params.groupHeadingLevel }} class="ds_task-list-heading">{{group.title}}</{{params.groupHeadingLevel}}>
        {%- endif %}
        {%- if group.content %}
        <p class="ds_task-list-intro">{{group.content}}</p>
        {%- endif %}
        <ul class="ds_task-list">
        {%- for item in group.tasks %}
            {{task({
                content: item.content,
                headingLevel: taskHeadingLevel,
                href: item.href,
                id: item.id,
                status: item.status,
                title: item.title
            })}}
        {%- endfor %}
        </ul>
    </li>
    {%- endfor %}
</ul>
{%- endif %}
{%- endmacro -%}

{{taskList({
    groups: groups,
    groupHeadingLevel: groupHeadingLevel,
    headingLevel: headingLevel,
    intro: intro,
    taskHeadingLevel: taskHeadingLevel,
    tasks: tasks,
    title: title
})}}
