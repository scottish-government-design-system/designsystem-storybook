{%- macro contactDetails(params) -%}
<div class="ds_contact-details">
    {%- if params.heading %}
    <h2 class="ds_contact-details__title">{{ params.heading }}</h2>
    {% endif -%}
    {%- if params.layout %} <div class="{{ params.layout }}">{% endif -%}
    {%- for list in params.lists -%}
    <div class="ds_contact-details__list">
        {%- if list.prefix -%}
        {{ list.prefix | safe }}
        {% endif -%}
        <dl>
            {%- for item in list.items -%}
            <div class="ds_contact-details__item">
                <dt {%- if item.hideLabel %} class="visually-hidden"{%- endif -%}>{{ item.label }}</dt>
                {%- for subitem in item.subitems -%}
                <dd {%- if subitem.ignoreTranslate %} translate="no"{%- endif -%}{%- if subitem.isSocialItem %} class="ds_contact-details__social-item"{%- endif -%}>
                    {%- if subitem.icon %}
                    <img class="ds_contact-details__social-icon" src="{{ subitem.icon }}" alt="" aria-hidden="true">
                    {% endif -%}
                    {{ subitem.content | safe }}
                </dd>
                {% endfor -%}
            </div>
            {%- endfor -%}
        </dl>
        {%- if list.suffix %}
        {{ list.suffix | safe }}
        {% endif -%}
    </div>
    {% endfor -%}
    {%- if params.isLayout %}</div>{% endif -%}
</div>
{%- endmacro -%}

{{contactDetails({
    heading: heading,
	layout: layout,
	lists: lists
})}}
