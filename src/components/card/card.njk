{%- macro card(params) -%}
{%- from 'src/components/button/button.njk' import button -%}
{%- from 'src/components/page-metadata/page-metadata.njk' import pageMetadata -%}
{%- if params.isAdaptive %}
<div class="ds_card-container">
{% endif -%}
<{{ params.tagName | default('div') }} class="ds_card{%- if params.isNav %}  ds_card--hover{% endif -%}{%- if params.isGrey %}  ds_card--background-secondary{% endif -%}{%- if params.isHorizontal %}  ds_card--horizontal{% endif -%}{%- if params.isHorizontalSmall %}  ds_card--horizontal-small{% endif -%}">
    {%- if params.image and params.image != 'none' %}
    <div class="ds_card__media {%- if params.imageCover %}  ds_card__media--cover{%- endif -%}{%- if params.imageWidth and params.imageWidth != 'default' %}  {{ params.imageWidth }}{%- endif -%}">
        {%- if params.imageAspect and params.imageAspect != 'none' %}
        <div class="ds_aspect-box {%- if params.imageAspect != 'default' %} {{ params.imageAspect }}{%- endif -%}">
        {% endif -%}
            <img alt="" aria-hidden="true" {%- if params.imageAspect and params.imageAspect != 'none' %} class="ds_aspect-box__inner"{%- endif -%} src="/images/placeholders/{{ params.image }}.jpg"/>
        {%- if params.imageAspect and params.imageAspect != 'none' %}
        </div>
        {% endif -%}
    </div>
    {% endif -%}
    <div class="ds_card__content">
        <div class="ds_card__content-header">
            {%- if params.hasNotification %}
            <span class="ds_notification-tag__wrapper">
            {%- endif -%}
            {%- if params.icon == "cog" %}
